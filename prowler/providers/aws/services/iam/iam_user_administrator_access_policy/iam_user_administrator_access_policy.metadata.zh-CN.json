{
  "Provider": "aws",
  "CheckID": "iam_user_administrator_access_policy",
  "CheckTitle": "确保没有 IAM 用户具有管理员访问策略",
  "CheckType": [],
  "ServiceName": "iam",
  "SubServiceName": "",
  "ResourceIdTemplate": "arn:partition:service:region:account-id:resource-id",
  "Severity": "high",
  "ResourceType": "AwsIamUser",
  "ResourceGroup": "IAM",
  "Description": "此检查确保您的 AWS 账户中没有 IAM 用户附加了“AdministratorAccess”策略。具有此策略的 IAM 用户对所有 AWS 服务和资源具有不受限制的访问权限，如果被滥用，会带来重大的安全风险。",
  "Risk": "具有管理员级别权限的 IAM 用户可以对 AWS 环境中的任何资源执行任何操作。如果不必要地将这些权限授予用户或授予没有足够知识的个人，可能会导致安全漏洞、数据泄露、数据丢失或意外费用。",
  "RelatedUrl": "https://docs.aws.amazon.com/IAM/latest/UserGuide/id_users.html",
  "Remediation": {
    "Code": {
      "CLI": "aws iam detach-user-policy --user-name <username> --policy-arn arn:aws:iam::aws:policy/AdministratorAccess",
      "NativeIaC": "",
      "Other": "https://www.trendmicro.com/cloudoneconformity/knowledge-base/aws/IAM/admin-permissions.html",
      "Terraform": ""
    },
    "Recommendation": {
      "Text": "用更具体的权限替换“AdministratorAccess”策略，遵循最小权限原则。考虑实施诸如“IAM Master”和“IAM Manager”之类的 IAM 角色，以更安全地管理权限。",
      "Url": "https://docs.aws.amazon.com/IAM/latest/UserGuide/best-practices.html"
    }
  },
