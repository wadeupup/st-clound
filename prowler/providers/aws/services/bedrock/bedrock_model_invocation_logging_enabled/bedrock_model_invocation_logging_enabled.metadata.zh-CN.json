  "CheckID": "bedrock_model_invocation_logging_enabled",
  "CheckTitle": "确保为 Amazon Bedrock 启用了模型调用日志记录",
  "CheckType": [],
  "ServiceName": "bedrock",
  "SubServiceName": "",
  "ResourceIdTemplate": "arn:partition:bedrock:region:account-id:model/resource-id",
